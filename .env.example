# Copy to .env and fill in. .env is gitignored - never commit real values.

# MongoDB connection string.
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/wanderlust
# Local:  mongodb://127.0.0.1:27017/wanderlust
ATLASDB_URL=

# Session signing/encryption secret. Any long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=

# Cloudinary - only needed to upload listing images.
# Free account at https://cloudinary.com -> Dashboard shows all three.
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Optional. Defaults to 2000.
PORT=
