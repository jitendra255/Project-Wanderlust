<% layout("/layouts/boilerplate") -%>
  <style>
    #filters {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
    }

    .filter {
      text-align: center;
      margin-top: 2rem;
      margin-left: 2rem;
      opacity: 0.8;
    }

    .filter:hover {
      cursor: pointer;
      opacity: 1.1;
    }

    .filter>p {
      font-size: 0.8rem;
    }



    .float-end{
      text-decoration: none !important;
    }

    .filter-link {
      text-decoration: none;
      color: inherit;
    }

    .filter.active-filter {
      opacity: 1;
      font-weight: 600;
    }

    .filter.active-filter > div {
      color: #fe424d;
    }

    .pagination .page-link {
      color: #fe424d;
    }

    .pagination .page-item.active .page-link {
      background-color: #fe424d;
      border-color: #fe424d;
      color: #fff;
    }

    .pagination .page-item.disabled .page-link {
      color: #adb5bd;
    }


    .meta {
      font-size: 0.82rem;
      color: #6c757d;
    }

    .toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-top: 1rem;
    }
  </style>

  <div class="d-flex align-items-start flex-wrap mt-3 mb-1">
    <div class="me-auto">
      <h4 class="mb-1">Near <%= campus.shortName %></h4>
      <p class="meta mb-0">
        Hostels, messes, food and everyday shops around <%= campus.area %> &mdash;
        sorted by how far they are from the campus gate.
      </p>
    </div>
    <a href="/listings/new" class="btn btn-danger btn-sm mt-1">Add a place</a>
  </div>

  <%
    const filterCategories = categories;

    const currentSearch = (typeof searchQuery !== "undefined" && searchQuery) ? searchQuery : "";
    const currentCategory = (typeof activeFilter !== "undefined" && activeFilter) ? activeFilter : "";
    const pager = (typeof pagination !== "undefined" && pagination) ? pagination : null;
    const currentSort = (typeof sortKey !== "undefined" && sortKey) ? sortKey : "distance";
    const currentVeg = (typeof vegOnly !== "undefined") ? vegOnly : false;

    // Build a /listings URL that keeps the current search + category, applying
    // any overrides. Pass null for a param to drop it.
    const listingsUrl = (overrides = {}) => {
      const params = new URLSearchParams();
      if (currentSearch) params.set("location", currentSearch);
      if (currentCategory) params.set("category", currentCategory);
      if (currentSort && currentSort !== "distance") params.set("sort", currentSort);
      if (currentVeg) params.set("veg", "1");
      for (const [key, value] of Object.entries(overrides)) {
        if (value === null || value === undefined || value === "") params.delete(key);
        else params.set(key, value);
      }
      const qs = params.toString();
      return qs ? `/listings?${qs}` : "/listings";
    };
  %>
  <div id="filters">
    <% for (let cat of filterCategories) { %>
      <% const isActive = currentCategory === cat.label; %>
      <a href="<%= isActive ? listingsUrl({ category: null, page: null }) : listingsUrl({ category: cat.label, page: null }) %>" class="filter-link">
        <div class="filter <%= isActive ? 'active-filter' : '' %>">
          <div><i class="fa-solid <%= cat.icon %>"></i></div>
          <p><%= cat.label %></p>
        </div>
      </a>
    <% } %>
  </div>

  <div class="toolbar">
    <span class="meta">Sort:</span>
    <% const sorts = [
         { key: "distance",  label: "Nearest" },
         { key: "priceLow",  label: "Price: low to high" },
         { key: "priceHigh", label: "Price: high to low" },
         { key: "newest",    label: "Recently added" },
       ]; %>
    <% for (let s of sorts) { %>
      <a href="<%= listingsUrl({ sort: s.key === 'distance' ? null : s.key, page: null }) %>"
        class="btn btn-sm <%= currentSort === s.key ? 'btn-danger' : 'btn-outline-secondary' %>">
        <%= s.label %>
      </a>
    <% } %>

    <span class="ms-2">
      <a href="<%= listingsUrl({ veg: currentVeg ? null : '1', page: null }) %>"
        class="btn btn-sm <%= currentVeg ? 'btn-success' : 'btn-outline-success' %>">
        Pure veg only
      </a>
    </span>
  </div>
  <% if (currentSearch || currentCategory) { %>
    <div class="alert alert-info">
      <% if (currentCategory) { %>
        Showing category: <strong><%= currentCategory %></strong><% if (currentSearch) { %> in <strong><%= currentSearch %></strong><% } %>
      <% } else { %>
        Showing results for: <strong><%= currentSearch %></strong>
      <% } %>
      <% if (pager) { %>&mdash; <%= pager.total %> listing<%= pager.total === 1 ? "" : "s" %><% } %>
      <a href="/listings" class="float-end">Clear all</a>
    </div>
  <% } %>

  <% if (!listings.length) { %>
    <div class="alert alert-warning">
      No listings found<% if (currentCategory) { %> in <strong><%= currentCategory %></strong><% } %><% if (currentSearch) { %> matching <strong><%= currentSearch %></strong><% } %>.
    </div>
  <% } %>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3 g-3">
    <% for (let listing of listings) { %>
      <% const meta = categoryMeta(listing.category); %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card h-100">
            <% if (listing.image && listing.image.url) { %>
              <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>"
                style="height: 12rem; object-fit: cover;">
            <% } else { %>
              <%# No photo: OSM has none for this area and we do not fake them. %>
              <div class="card-img-top place-thumb" style="height: 12rem; background-color: <%= meta.tint %>;">
                <i class="fa-solid <%= meta.icon %>"></i>
                <span class="thumb-label">Photo needed</span>
              </div>
            <% } %>

            <div class="card-body">
              <p class="card-text mb-1">
                <b><%= listing.title %></b>
              </p>

              <p class="card-text meta mb-2">
                <span class="badge rounded-pill text-bg-light"><%= listing.category %></span>
                <% if (listing.distanceFromCampus != null) { %>
                  &middot; <%= formatDistance(listing.distanceFromCampus) %> from campus
                <% } %>
              </p>

              <p class="card-text mb-0">
                <% if (listing.price) { %>
                  <b>&#8377;<%= listing.price.toLocaleString("en-IN") %></b>
                  <span class="meta"><%= listing.priceUnit %></span>
                <% } else { %>
                  <span class="meta">Price not listed yet</span>
                <% } %>
              </p>

              <p class="card-text mt-2 mb-0">
                <% if (listing.vegOnly) { %>
                  <span class="badge text-bg-success">Pure veg</span>
                <% } %>
                <% if (listing.gender) { %>
                  <span class="badge text-bg-secondary"><%= listing.gender %></span>
                <% } %>
                <% if (listing.verified) { %>
                  <span class="badge text-bg-primary"><i class="fa-solid fa-circle-check"></i> Verified</span>
                <% } else { %>
                  <span class="badge text-bg-warning">Unverified</span>
                <% } %>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <% if (pager && pager.totalPages > 1) { %>
    <%
      const windowSize = 2;
      const from = Math.max(1, pager.page - windowSize);
      const to = Math.min(pager.totalPages, pager.page + windowSize);
      // Page 1 is the bare URL - keeps ?page=1 out of the address bar.
      const pageHref = (n) => listingsUrl({ page: n === 1 ? null : n });
    %>
    <nav aria-label="Listing pages" class="mt-4">
      <ul class="pagination justify-content-center flex-wrap">
        <li class="page-item <%= pager.page === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="<%= pageHref(pager.page - 1) %>">Previous</a>
        </li>

        <% if (from > 1) { %>
          <li class="page-item"><a class="page-link" href="<%= pageHref(1) %>">1</a></li>
          <% if (from > 2) { %>
            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
          <% } %>
        <% } %>

        <% for (let n = from; n <= to; n++) { %>
          <li class="page-item <%= n === pager.page ? 'active' : '' %>">
            <a class="page-link" href="<%= pageHref(n) %>"><%= n %></a>
          </li>
        <% } %>

        <% if (to < pager.totalPages) { %>
          <% if (to < pager.totalPages - 1) { %>
            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
          <% } %>
          <li class="page-item"><a class="page-link" href="<%= pageHref(pager.totalPages) %>"><%= pager.totalPages %></a></li>
        <% } %>

        <li class="page-item <%= pager.page === pager.totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="<%= pageHref(pager.page + 1) %>">Next</a>
        </li>
      </ul>
      <p class="text-center text-muted small">
        Page <%= pager.page %> of <%= pager.totalPages %> &middot; <%= pager.total %> listings
      </p>
    </nav>
  <% } %>

  <p class="meta mt-4 mb-5">
    Place data partly from
    <a href="https://www.openstreetmap.org/copyright" class="text-muted">OpenStreetMap contributors</a>
    (ODbL). Entries marked <span class="badge text-bg-warning">Unverified</span> have not been
    checked on the ground &mdash; help by correcting them.
  </p>