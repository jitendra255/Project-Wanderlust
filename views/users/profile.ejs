<% layout("/layouts/boilerplate") -%>
  <style>
    .profile-header {
      border-bottom: 1px solid #dee2e6;
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }

    .profile-avatar {
      width: 4.5rem;
      height: 4.5rem;
      border-radius: 50%;
      background-color: #fe424d;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .stat-pill {
      background-color: #f8f9fa;
      border-radius: 1rem;
      padding: 0.75rem 1.25rem;
      text-align: center;
      min-width: 6rem;
    }

    .stat-pill .stat-value {
      font-size: 1.5rem;
      font-weight: 600;
      line-height: 1;
    }

    .stat-pill .stat-label {
      font-size: 0.75rem;
      color: #6c757d;
    }

    .profile-card-link {
      text-decoration: none;
      color: inherit;
    }

    .meta {
      font-size: 0.82rem;
      color: #6c757d;
    }

    .thread {
      border-left: 3px solid #dee2e6;
      padding-left: 0.9rem;
    }

    .thread.unanswered {
      border-left-color: #ffc107;
    }

    .no-photo-sm {
      height: 9rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #f2f2f2;
      color: #c9c9c9;
      font-size: 2.5rem;
    }
  </style>

  <div class="row mt-4">
    <div class="col-lg-10 offset-lg-1">

      <div class="profile-header d-flex align-items-center gap-3 flex-wrap">
        <div class="profile-avatar"><%= currUser.username.charAt(0) %></div>
        <div class="me-auto">
          <h3 class="mb-0">
            <%= currUser.username %>
            <% if (currUser.isAdmin) { %>
              <span class="badge text-bg-dark align-middle">admin</span>
            <% } %>
          </h3>
          <p class="meta mb-0"><%= currUser.email %></p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <div class="stat-pill">
            <div class="stat-value"><%= listings.length %></div>
            <div class="stat-label">Added</div>
          </div>
          <div class="stat-pill">
            <div class="stat-value"><%= reviews.length %></div>
            <div class="stat-label">Review<%= reviews.length === 1 ? "" : "s" %></div>
          </div>
          <div class="stat-pill">
            <div class="stat-value"><%= enquiriesReceived.filter(e => !e.reply).length %></div>
            <div class="stat-label">To answer</div>
          </div>
        </div>
      </div>

      <% if (currUser.isAdmin) { %>
        <a href="/admin/queue" class="btn btn-sm btn-dark mb-4">Open moderation queue</a>
      <% } %>

      <%# ---- Questions people asked about places this user added ---- %>
      <h4 class="mb-1">Questions about my places</h4>
      <p class="meta mb-3">Juniors asking about places you added. Answering helps everyone.</p>

      <% if (!enquiriesReceived.length) { %>
        <div class="alert alert-light border py-3 meta mb-4">No questions yet.</div>
      <% } else { %>
        <div class="mb-4">
          <% for (let enquiry of enquiriesReceived) { %>
            <div class="thread <%= enquiry.reply ? "" : "unanswered" %> mb-3">
              <p class="meta mb-1">
                <strong>@<%= enquiry.from ? enquiry.from.username : "someone" %></strong>
                asked about
                <% if (enquiry.listing) { %>
                  <a href="/listings/<%= enquiry.listing._id %>" class="profile-card-link fw-bold">
                    <%= enquiry.listing.title %>
                  </a>
                <% } else { %>
                  a place that has since been removed
                <% } %>
              </p>
              <p class="mb-2"><%= enquiry.message %></p>

              <% if (enquiry.reply) { %>
                <p class="meta mb-0"><strong>You replied:</strong> <%= enquiry.reply %></p>
              <% } else if (enquiry.listing) { %>
                <form method="post" action="/listings/<%= enquiry.listing._id %>/enquiries/<%= enquiry._id %>/reply"
                  class="row g-2">
                  <div class="col-md-9">
                    <input type="text" name="enquiry[reply]" class="form-control form-control-sm"
                      placeholder="Write a reply..." required>
                  </div>
                  <div class="col-md-3">
                    <button class="btn btn-sm btn-danger w-100">Reply</button>
                  </div>
                </form>
              <% } %>
            </div>
          <% } %>
        </div>
      <% } %>

      <%# ---- Questions this user asked ---- %>
      <h4 class="mb-3">Questions I've asked</h4>

      <% if (!enquiriesSent.length) { %>
        <div class="alert alert-light border py-3 meta mb-4">
          You haven't asked about any place yet.
        </div>
      <% } else { %>
        <div class="mb-4">
          <% for (let enquiry of enquiriesSent) { %>
            <div class="thread <%= enquiry.reply ? "" : "unanswered" %> mb-3">
              <p class="meta mb-1">
                You asked
                <strong>@<%= enquiry.to ? enquiry.to.username : "someone" %></strong>
                about
                <% if (enquiry.listing) { %>
                  <a href="/listings/<%= enquiry.listing._id %>" class="profile-card-link fw-bold">
                    <%= enquiry.listing.title %>
                  </a>
                <% } else { %>
                  a place that has since been removed
                <% } %>
              </p>
              <p class="mb-1"><%= enquiry.message %></p>
              <% if (enquiry.reply) { %>
                <p class="meta mb-0"><strong>Reply:</strong> <%= enquiry.reply %></p>
              <% } else { %>
                <p class="meta mb-0"><em>Waiting for a reply.</em></p>
              <% } %>
            </div>
          <% } %>
        </div>
      <% } %>

      <%# ---- Places this user added ---- %>
      <div class="d-flex align-items-center mb-1">
        <h4 class="mb-0 me-auto">Places I've added</h4>
        <a href="/listings/new" class="btn btn-danger btn-sm">Add a place</a>
      </div>
      <% if (pendingCount) { %>
        <p class="meta mb-3">
          <%= pendingCount %> of these <%= pendingCount === 1 ? "is" : "are" %> still awaiting
          review and <%= pendingCount === 1 ? "is" : "are" %> not public yet.
        </p>
      <% } else { %>
        <p class="meta mb-3">Know a good mess, hostel or chai spot? Add it.</p>
      <% } %>

      <% if (!listings.length) { %>
        <div class="alert alert-light border text-center py-4 mb-5">
          <p class="mb-2">You haven't added any places yet.</p>
          <a href="/listings/new" class="btn btn-danger btn-sm">Add your first place</a>
        </div>
      <% } else { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-3 mb-5">
          <% for (let listing of listings) { %>
            <% const icon = (categories.find(c => c.label === listing.category) || {}).icon || "fa-location-dot"; %>
            <div class="col">
              <div class="card h-100">
                <a href="/listings/<%= listing._id %>" class="profile-card-link">
                  <% if (listing.image && listing.image.url) { %>
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>"
                      style="height: 9rem; object-fit: cover;">
                  <% } else { %>
                    <div class="card-img-top no-photo-sm"><i class="fa-solid <%= icon %>"></i></div>
                  <% } %>
                  <div class="card-body pb-2">
                    <p class="card-text mb-1"><b><%= listing.title %></b></p>
                    <p class="card-text meta mb-2">
                      <%= listing.category %>
                      <% if (listing.distanceFromCampus != null) { %>
                        &middot; <%= formatDistance(listing.distanceFromCampus) %>
                      <% } %>
                    </p>
                    <p class="card-text mb-0">
                      <% if (listing.status === "pending") { %>
                        <span class="badge text-bg-warning">Awaiting review</span>
                      <% } else if (listing.status === "rejected") { %>
                        <span class="badge text-bg-danger">Rejected</span>
                      <% } else if (listing.verified) { %>
                        <span class="badge text-bg-primary">Verified</span>
                      <% } else { %>
                        <span class="badge text-bg-secondary">Unverified</span>
                      <% } %>
                    </p>
                  </div>
                </a>
                <div class="card-body pt-0 d-flex gap-2">
                  <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-dark">Edit</a>
                  <form method="post" action="/listings/<%= listing._id %>?_method=Delete"
                    onsubmit="return confirm('Delete this place?');">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>

      <%# ---- Reviews written ---- %>
      <h4 class="mb-3">My reviews</h4>
      <% if (!reviews.length) { %>
        <div class="alert alert-light border text-center py-4 mb-5">
          You haven't reviewed any place yet.
        </div>
      <% } else { %>
        <div class="row row-cols-lg-2 row-cols-1 g-3 mb-5">
          <% for (let review of reviews) { %>
            <% const reviewed = listingByReview.get(review._id.toString()); %>
            <div class="col">
              <div class="card h-100">
                <div class="card-body">
                  <h6 class="card-title mb-1">
                    <% if (reviewed) { %>
                      <a href="/listings/<%= reviewed._id %>" class="profile-card-link fw-bold">
                        <%= reviewed.title %>
                      </a>
                    <% } else { %>
                      <span class="text-muted fst-italic">Place no longer listed</span>
                    <% } %>
                  </h6>
                  <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                  <p class="card-text"><%= review.comment %></p>
                  <% if (reviewed) { %>
                    <form method="post"
                      action="/listings/<%= reviewed._id %>/reviews/<%= review._id %>?_method=Delete"
                      onsubmit="return confirm('Delete this review?');">
                      <button class="btn btn-sm btn-outline-dark">Delete review</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>

    </div>
  </div>
