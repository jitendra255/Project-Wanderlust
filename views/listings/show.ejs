<% layout("/layouts/boilerplate") -%>
    <%# Leaflet is only needed on this page, so it is not in the shared layout. %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

    <style>
        #listing-map {
            height: 24rem;
            border-radius: 0.75rem;
            z-index: 0;
        }
    </style>

    <div class="row">
        <div class="col-8 offset-2 mt-3">
            <h3>
                <%=listing.title%>
            </h3>
        </div>
        <div class="card col-6 offset-2 listing-card">
            <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text mt-2">
                <p class="card-text">Owned by : <%=listing.owner.username%>
                </p>
                <br>
                <%=listing.description%>
                    <br>
                    &#8377;<%=listing.price.toLocaleString("en-IN")%>
                        <br>
                        <%=listing.location%>
                            <br>
                            <%=listing.country%>
                                <br>
                                </p>
            </div>
        </div>
        <br>


    </div>
    <% if(currUser && listing.owner._id.equals(currUser._id)) {%>
        <div class="btns">
            <a href="/listings/<%=listing._id%>/edit" class="btn btn-danger col-1 offset-2 mt-3">Edit</a>

            <form method="post" action="/listings/<%=listing._id%>?_method=Delete">
                <button class="btn btn-dark  offset-4 mt-3">Delete</button>
            </form>
        </div>
        <% } %>

            <% const isOwner = currUser && listing.owner._id.equals(currUser._id); %>
            <hr class="col-8 offset-2">
            <div class="col-8 offset-2 mb-3 mt-3">
                <h4>Book this stay</h4>

                <% if (!currUser) { %>
                    <p class="text-muted">
                        <a href="/login">Log in</a> to book this listing.
                    </p>
                <% } else if (isOwner) { %>
                    <p class="text-muted">This is your listing &mdash; you can't book it yourself.</p>
                <% } else { %>
                    <form action="/listings/<%= listing._id %>/bookings" method="post" class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label for="checkIn" class="form-label">Check in</label>
                            <input type="date" id="checkIn" name="booking[checkIn]" class="form-control"
                                min="<%= todayIso %>" required>
                        </div>
                        <div class="col-md-3">
                            <label for="checkOut" class="form-label">Check out</label>
                            <input type="date" id="checkOut" name="booking[checkOut]" class="form-control"
                                min="<%= todayIso %>" required>
                        </div>
                        <div class="col-md-2">
                            <label for="guests" class="form-label">Guests</label>
                            <input type="number" id="guests" name="booking[guests]" class="form-control" value="1"
                                min="1" required>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-danger w-100">
                                Book &middot; &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                            </button>
                        </div>
                    </form>
                <% } %>

                <% if (bookings && bookings.length) { %>
                    <p class="text-muted mt-3 mb-1" style="font-size: 0.9rem;">Already booked:</p>
                    <ul class="list-unstyled mb-0" style="font-size: 0.9rem;">
                        <% for (let booked of bookings) { %>
                            <li class="text-muted">
                                &bull; <%= booked.checkIn.toISOString().slice(0, 10) %>
                                &rarr; <%= booked.checkOut.toISOString().slice(0, 10) %>
                            </li>
                        <% } %>
                    </ul>
                <% } %>
            </div>

            <% const point = listing.geometry && listing.geometry.coordinates; %>
            <% if (point && point.length === 2) { %>
                <hr class="col-8 offset-2">
                <div class="col-8 offset-2 mb-3 mt-3">
                    <h4>Where you'll be</h4>
                    <p class="text-muted mb-2">
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                    <div id="listing-map" data-lng="<%= point[0] %>" data-lat="<%= point[1] %>"
                        data-title="<%= listing.title %>"></div>
                </div>
            <% } %>

            <hr class="col-8 offset-2">
            <div class="col-8 offset-2 mb-3 mt-3">

                <% if(currUser) {%>
                    <h4>Leave a Review</h4>
                    <form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">

                        <div class="mb-3 mt-3">
                            <fieldset class="starability-slot">
                                <legend>Rating:</legend>
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                    checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3 mt-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                                required></textarea>
                            <div class="invalid-feedback">Please add some comment for review.</div>
                        </div>
                        <button class="btn btn-danger">Submit</button>
                    </form>

                    <% } %>

                        <% if(listing.reviews.length>0){%>
                            <hr>
                            <div class="row">
                                <p class="fw-bold">All reviews</p>
                                <%for(review of listing.reviews){ %>
                                    <div class="card col-5 ms-3 mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title mt-2">
                                                @<%=review.author.username%>
                                            </h5>
                                            <p class="starability-result card-text" data-rating="<%=review.rating%>">
                                            </p>
                                            <p class="card-text">
                                                <%=review.comment%>
                                            </p>

                                        </div>
                                        <% if(currUser && review.author._id.equals(currUser._id)) { %>
                                            <form class="mb-3" method="post"
                                                action="/listings/<%=listing._id %>/reviews/<%=review._id%>?_method=Delete">
                                                <button class="btn btn-sm btn-dark mt-2">Delete</button>
                                            </form>
                                            <% } %>

                                    </div>
                                    <% } %>
                            </div>
                            <%}%>
            </div>

            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
            <script>
                (function () {
                    const el = document.getElementById("listing-map");
                    if (!el || !window.L) return;

                    const lat = Number.parseFloat(el.dataset.lat);
                    const lng = Number.parseFloat(el.dataset.lng);
                    if (Number.isNaN(lat) || Number.isNaN(lng)) return;

                    const map = L.map(el).setView([lat, lng], 11);

                    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
                        maxZoom: 19,
                        attribution:
                            '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                    }).addTo(map);

                    L.marker([lat, lng]).addTo(map).bindPopup(el.dataset.title).openPopup();
                })();
            </script>